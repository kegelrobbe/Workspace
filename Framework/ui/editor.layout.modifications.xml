<UIModification  xmlns="urn:kwsoft:mtext:tonic:ui">
	<ActionModifications>
		<ActionModification
			enabledIf="$Metadata.State.valueOf() !== 'Finished'"
			visibleIf="true"
			name="Finalize"
			code="ActionCode:EXECUTE_SCRIPT"
			title="Finalize"
			title-de_DE="Finalisieren"
			description="Save document, send to OMS and close"
			description-de_DE="Dokument speichern, an OMS senden und schließen"
			icon="white_editor_menuprint.png"
			>
		<Script><![CDATA[
			load("Scripts/Actions.js");
			finalizeDocument($context, $Metadata);
		]]></Script>
		</ActionModification>
		<ActionModification
			enabledIf="$Metadata.State.valueOf() !== 'Finished'"
			visibleIf="$Metadata.State.valueOf() !== 'Finished' &amp;&amp; true"
			name="CustomSave"
			code="ActionCode:EXECUTE_SCRIPT"
			shortcut="'CTRL S'"
			title="Save"
			title-de_DE="Speichern"
			description="Save document"
			description-de_DE="Dokument speichern"
			icon="white_editor_menusave.png"
			>
		<Script><![CDATA[
			$context.beginBulkUpdate();
			$context.setDataValue($Metadata.OutputMode,'');
			$context.setDataValue($Metadata.State,'Saved');
			$context.setDataValue($Metadata.Assignee,$CurrentUser.guid);
			$context.endBulkUpdate();
			$context.save();
		]]></Script>
		</ActionModification>
		<ActionModification
			visibleIf="false"
			enabledIf="false"
			code="ActionCode:DOCUMENT_SAVE"
			>
		</ActionModification>
	</ActionModifications>
</UIModification>