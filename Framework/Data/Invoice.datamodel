<?xml version="1.0" encoding="UTF-8"?>
<DataModel>
   <Node multiple="false" name="CrossIndustryInvoice">
      <Settings>
         <Script/>
      </Settings>
      <Node multiple="false"
            name="ExchangedDocumentContext"
            ref="\\Framework\Data\ExchangedDocumentContext.datamodel">
         <Settings>
            <Script/>
         </Settings>
      </Node>
      <Node multiple="false"
            name="ExchangedDocument"
            ref="\\Framework\Data\ExchangedDocument.datamodel">
         <Settings>
            <Script/>
         </Settings>
      </Node>
      <Node multiple="false"
            name="SupplyChainTradeTransaction"
            ref="\\Framework\Data\SupplyChainTradeTransaction.datamodel">
