      </Node>
   </Node>
   <Node data-type="TEXT"
         hierarchical="FLAT"
         multiple="false"
         name="addAttachment"
         searchable="false">
      <Settings>
         <Validation allow-empty-value="true"
                     dialog-field=""
                     label=""
                     operator="ANY"
                     validation-type="ANY_VALUE">
            <Values/>
         </Validation>
         <Script>text = toXml($current.parent().CrossIndustryInvoice);
addDocumentAttachment("/targetFormatAttachments/ZUGFeRD-invoice.xml", "&lt;" + $CrossIndustryInvoice.name() + "&gt;\n" + text + "\n&lt;/" + $CrossIndustryInvoice.name() + "&gt;");</Script>
      </Settings>
   </Node>
