<?xml version="1.0" encoding="UTF-8"?>
<DataNodeSubtypes>
   <DataNodeSubtype data-type="NUMBER" name="NumberNeverEmpty">
      <Settings>
         <Validation allow-empty-value="true"
                     dialog-field=""
                     label=""
                     operator="ANY"
                     validation-type="ANY_VALUE">
            <Values/>
         </Validation>
         <Format>
            <Input decimal-separator="46" thousand-separator="44">
               <Script>0 + $inputvalue;</Script>
            </Input>
         </Format>
      </Settings>
   </DataNodeSubtype>
   <DataNodeSubtype data-type="NUMBER" name="Number2NKdottedDecimal">
      <Settings>
         <Validation allow-empty-value="true"
                     dialog-field=""
                     label=""
                     operator="ANY"
                     validation-type="ANY_VALUE"/>
         <Format>
            <Output currency-format="BEFORE_WITH_SPACE"
                    currency-symbol="€"
                    decimal-separator="46"
                    formatting-type="NUMBER"
                    fractional-digits="2"
                    leading-zeros="1"
                    text-prefix=""
                    text-suffix=""
                    thousand-separator="44"
                    use-current-locale="false"/>
         </Format>
      </Settings>
   </DataNodeSubtype>
   <DataNodeSubtype data-type="NUMBER" name="Number4NKdottedDecimal">
      <Settings>
         <Validation allow-empty-value="true"
                     dialog-field=""
                     label=""
                     operator="ANY"
                     validation-type="ANY_VALUE"/>
         <Format>
            <Output currency-format="BEFORE_WITH_SPACE"
                    currency-symbol="€"
                    decimal-separator="46"
                    formatting-type="NUMBER"
                    fractional-digits="2"
                    leading-zeros="1"
                    text-prefix=""
                    text-suffix=""
                    thousand-separator="44"
                    use-current-locale="false"/>
         </Format>
      </Settings>
   </DataNodeSubtype>
</DataNodeSubtypes>
